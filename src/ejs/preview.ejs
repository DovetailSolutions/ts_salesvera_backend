<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<style>
body { font-family: Arial; font-size: 14px; color:#333; }

/* Header */
.header {
  display:flex;
  justify-content:space-between;
  border-bottom:2px solid #000;
  margin-bottom:20px;
}
.logo img { width:100px; }
.company { text-align:right; }

/* Table */
table {
  width:100%;
  border-collapse: collapse;
  margin-top:10px;
}
th, td {
  border:1px solid #ddd;
  padding:8px;
}
th { background:#f5f5f5; }

/* Prevent breaking rows */
tr { page-break-inside: avoid; }

/* Amount Box */
.amount-box {
  width:300px;
  margin-left:auto;
  margin-top:20px;
}

/* Signature */
.signature-section {
  margin-top:50px;
  display:flex;
  justify-content:space-between;
}
.signature-section img {
  height:60px;
}
</style>
</head>

<body>

<!-- Header -->
<div class="header">
  <div class="logo">
    <img src="<%= logo %>">
  </div>
  <div class="company">
    <strong><%= companyName %></strong><br>
    <%= address %><br>
    GST: <%= gstin %>
  </div>
</div>

<!-- Info -->
<p><strong>Quotation:</strong> <%= quotationNumber %></p>
<p><strong>Date:</strong> <%= date %></p>
<p><strong>From:</strong> <%= fromName %></p>

<h3>To</h3>
<p><%= toName %></p>
<p><%= toAddress %></p>
<p><%= contactNumber %></p>

<!-- Table -->
<h3>Quotation Details</h3>
<table>
<thead>
<tr>
<th>#</th>
<th>Category</th>
<th>Service</th>
<th>Amount</th>
</tr>
</thead>

<tbody>
<% items.forEach((item, index) => { %>
<tr>
<td><%= index + 1 %></td>
<td><%= item.category %></td>
<td><%= item.service %></td>
<td>₹ <%= item.amount %></td>
</tr>
<% }) %>
</tbody>
</table>

<!-- Amount Summary -->
<div class="amount-box">
<table>
<tr>
  <td>Subtotal</td>
  <td>₹ <%= subtotal %></td>
</tr>

<tr>
  <td>Discount</td>
  <td>- ₹ <%= discount %></td>
</tr>

<tr>
  <td>Taxable</td>
  <td>₹ <%= taxableAmount %></td>
</tr>

<!-- ✅ GST Split Logic -->
<% if (cgst > 0 && sgst > 0) { %>
<tr>
  <td>CGST (<%= gstRate / 2 %>%)</td>
  <td>₹ <%= cgst %></td>
</tr>
<tr>
  <td>SGST (<%= gstRate / 2 %>%)</td>
  <td>₹ <%= sgst %></td>
</tr>
<% } else { %>
<tr>
  <td>IGST (<%= gstRate %>%)</td>
  <td>₹ <%= igst %></td>
</tr>
<% } %>

<tr>
  <td><strong>Total</strong></td>
  <td><strong>₹ <%= finalAmount %></strong></td>
</tr>
</table>
</div>

<!-- Notes -->
<div style="margin-top:30px;">
<strong>Notes:</strong>
<p><%= notes %></p>
</div>

<!-- Signature -->
<div class="signature-section">
  <div>
    <p>Authorized Signature</p>
    <img src="<%= signature %>">
  </div>

  <div>
    <p>Company Stamp</p>
    <img src="<%= stamp %>">
  </div>
</div>

</body>
</html>